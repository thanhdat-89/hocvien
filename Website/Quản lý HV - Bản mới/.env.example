# ================================================================
# Firebase (chọn 1 trong 2 cách)
# Cách 1 (local dev): để trống, đặt file firebase-service-account.json ở gốc project
# Cách 2 (production/Vercel): dán nội dung JSON của service account vào đây
# ================================================================
FIREBASE_SERVICE_ACCOUNT_JSON=

# ================================================================
# App
# ================================================================
JWT_SECRET=change-this-to-a-random-secret-key-at-least-32-chars
NODE_ENV=production
PORT=3000

# ================================================================
# Zalo OA (tuỳ chọn)
# ================================================================
ZALO_OA_ID=
ZALO_OA_SECRET=
ZALO_ACCESS_TOKEN=
ZALO_REFRESH_TOKEN=
ZALO_WEBHOOK_SECRET=
