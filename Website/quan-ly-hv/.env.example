# ================================================================
# Firebase (chọn 1 trong 2 cách)
# Cách 1 (local dev): để trống, đặt file firebase-service-account.json ở gốc project
# Cách 2 (production/Vercel): dán nội dung JSON của service account vào đây
# ================================================================
FIREBASE_SERVICE_ACCOUNT_JSON=

# ================================================================
# App
# ================================================================
JWT_SECRET=change-this-to-a-random-secret-key-at-least-32-chars
NODE_ENV=production
PORT=3000

# ================================================================
# Zalo OA (tuỳ chọn) — gửi tin nhắn cá nhân khi PH đã follow OA
# ================================================================
ZALO_OA_ID=
ZALO_OA_SECRET=
ZALO_ACCESS_TOKEN=
ZALO_REFRESH_TOKEN=
ZALO_WEBHOOK_SECRET=

# ================================================================
# ZNS (Zalo Notification Service) — gửi thông báo template tới SĐT
# ================================================================
# App ZNS riêng, đăng ký tại https://developers.zalo.me/
# Template phải nộp Zalo duyệt qua portal trước khi dùng.
# Khi các biến chưa set: backend log warning + bỏ qua gọi API (không crash).
# ================================================================
ZNS_APP_ID=
ZNS_APP_SECRET=
ZNS_ACCESS_TOKEN=
ZNS_REFRESH_TOKEN=
ZNS_WEBHOOK_SECRET=
