{
  "version": 2,
  "regions": ["sin1"],
  "builds": [
    {
      "src": "src/index.ts",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 30
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/index.ts"
    }
  ],
  "crons": [
    { "path": "/api/activity/cleanup", "schedule": "0 3 * * 0" }
  ]
}
